# ==============================================================================
# Catering Outreach Backend — Environment Configuration Template
# Copy this file to '.env' and populate with actual credentials before running.
# ==============================================================================

# Core App Configurations
APP_NAME="Catering Outreach Platform"
APP_ENV="development" # development, staging, production
DEBUG=true
API_V1_PREFIX="/api/v1"
SECRET_KEY="generate-a-secure-random-key-in-production-with-openssl-rand-hex-32"

# Database Configuration
# format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/catering_outreach"

# Lead Generation (Google Places API)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# AI Outreach (OpenAI API)
OPENAI_API_KEY="your-openai-api-key-here"

# Communications (Email - SendGrid / SMS - Twilio)
SENDGRID_API_KEY="your-sendgrid-api-key-here"
TWILIO_ACCOUNT_SID="your-twilio-sid-here"
TWILIO_AUTH_TOKEN="your-twilio-auth-token-here"
